roots = ["/home", "/root", "/tmp", "/var/tmp", "/opt", "/srv"]
exclude = ["/proc", "/sys", "/dev", "/run", "/var/lib/docker",
           "/var/lib/containers", "/.snapshots", "/var/lib/clamav"]
exclude_regex = ['/node_modules/', '/\.git/']
one_file_system = true
follow_symlinks = false
max_size = "256M"
max_depth = 64
jobs = 8
timeout = 30
worker_recycle = 200
worker_memory_mb = 1024

[acceleration]
gpu = "auto"
min_gpu_entropy_size = "4M"

[clamav]
enabled = true
required = false
socket = "auto"

[yara]
enabled = true
required = false
extra_rule_dirs = []

[ioc]
hash_file = "pdfscan/rules/ioc_hashes.txt"
fuzzy = false
vt_hash_lookup = false
vt_submit_file = false

[quarantine]
mode = "none"

[report]
formats = ["jsonl", "csv", "md"]
min_score = 10
